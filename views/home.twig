{% extends "overall/base.twig" %}

{% block base %}

    {% set blocks = [
        {
            'name': 'hero-2',
            'fields': {
                'style': '',
                'title': 'Stylish electric scooter with a powerful battery',
                'description': 'Improved performance for long-distance travel. It works as simply as it looks.',
                'buttons': [
                    {'text': 'white', 'role': 'white', 'img': img_folder~'hero-bike-1.webp'},
                    {'text': 'black', 'role': 'black', 'img': img_folder~'hero-bike-2.webp'},
                ]
            }
        },
        {
            'name': 'text',
            'fields': {
                'title': 'About the Project',
                'content': '<p>This is a text block example. It uses the <strong>.typo</strong> class for rich text formatting — headings, lists, links, blockquotes, and tables are all styled automatically.</p><p>Use this block for any content sections that require formatted text output.</p>'
            }
        },
        {
            'name': 'form',
            'fields': {
                'title': 'Contact Us',
                'description': 'Have a question or want to work together? Fill out the form below.'
            }
        },
    ] %}

    {% for block in blocks %}
        {% include 'blocks/main/' ~ block.name ~ '.twig' with
            {
                'block_group': 'main',
                'block_name': block.name,
                'fields': block.fields,
            }
        %}
    {% endfor %}

{% endblock %}
