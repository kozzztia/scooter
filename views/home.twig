{% extends "overall/base.twig" %}

{% block base %}

    {% set blocks = [
        {
            'name': 'hero-2',
            'fields': {
            'style': 'margin-bottom: 50px;',
            'title': 'Stylish electric scooter with a powerful battery',
            'description': 'Improved performance for long-distance travel. It works as simply as it looks.',
            'buttons': [
                {'text': 'white', 'role': 'white', 'img': img_folder~'hero-bike-1.webp', 'decor': true},
                {'text': 'black', 'role': 'black', 'img': img_folder~'hero-bike-2.webp', 'decor': true},
            ]
        }
        },

        {
            'name': 'text',
            'fields': {
            'style': 'margin-bottom: 25px;',
            'class': '',
            'title': 'A powerful battery and economical charge consumption allow you to cover distances of up to 45 km'
        }
        },

        {
            'name': 'tab',
            'fields': {
            'style': 'margin-bottom: 50px;',
            'decor': 'one',
            'class': '',
            'name': 'tab',
            'tabs': [
                {'id': '1', 'title': 'Three speed modes', 'description': 'Three driving modes allow you to feel comfortable in any situation. "S" mode increases speed if you are running late for work. When strolling through the park, activate "D" mode. Turn on "Pedestrian" mode when driving on a busy street.', 'img': img_folder~"tab-1.webp",},
                {'id': '2', 'title': 'Energy recovery system', 'description': 'During braking and coasting, the system converts kinetic energy into electrical energy, allowing the scooter to increase its overall range.', 'img': img_folder~"tab-2.webp",},
                {'id': '3', 'title': 'Powerful battery', 'description': 'The scooter is equipped with a 12,800 mAh battery, allowing it to travel up to 45 km without recharging.', 'img': img_folder~"tab-3.webp",},
            ],
        }
        },

        {
            'name': 'banner',
            'fields': {
            'style': 'margin-bottom: 50px;',
            'class': '',
            'decor': true,
            'title': 'High movement speed',
            'content': 'An engine with a power of up to 600 W allows for speeds of up to 25 km/h.',
        }
        },

        {
            'name': 'text',
            'fields': {
            'style': 'margin-bottom: 25px;',
            'class': 'accented',
            'title': 'A laconic modern design with nothing superfluous',
        }
        },

        {
            'name': 'cards',
            'fields': {
            'style': 'margin-bottom: 100px;',
            'class': '',
            'decor': true,
            'cards': [
                {'title': 'Minimalistic design', 'content': 'The scooter\'s frame, components, and accessories are designed in a unified style, prioritizing user convenience. A single touch is all it takes to start the scooter.',
                    'img': img_folder~'card-1.webp'},
                {'title': 'User-friendly control panel', 'content': 'Conveniently located controls. Display 8 types of real-time data: speed, mode, battery charge, lock status, and more.',
                    'img': img_folder~'card-2.webp'},
            ],
        }
        },

        {
            'name': 'tab',
            'fields': {
            'style': 'margin-bottom: 50px;',
            'class': '',
            'name': 'two',
            'tabs': [
                {'id': '1', 'title': 'Bright running lights', 'description': 'A well-thought-out light dispersion angle allows for good visibility without blinding other road users.', 'img': img_folder~"tab-2-1.webp",},
                {'id': '2', 'title': 'Dual braking system', 'description': 'When you press the brake handle, the front and rear wheel systems are activated sequentially, reducing the braking distance and ensuring a safe and smooth stop.', 'img': img_folder~"tab-2-2.webp",},
                {'id': '3', 'title': 'Bright taillight', 'description': 'When the daytime running lights are turned on, the taillight turns on automatically. When you press the brake, it starts flashing, warning other road users.', 'img': img_folder~"tab-2-3.webp",},
                {'id': '4', 'title': 'Reflectors front, side and rear', 'description': 'Improved reflectors placed on four sides make your ride safer at night.', 'img': img_folder~"tab-2-4.webp",},
            ],
        }
        },


        {
            'name': 'single-banner',
            'fields': {
            'style': '',
            'class': '',
            'title': 'Mi Home mobile app',
            'content': 'Connect your scooter to the Mi Home mobile app and use it to lock and unlock the scooter, as well as view basic data such as mileage, speed, and battery level.',
            'img': img_folder~'single-banner.webp',
            'decor': true,
            'links': [
                {'url': '#', 'icon': img_folder~'store.webp',},
                {'url': '#', 'icon': img_folder~'google.webp',},
            ],
        }
        },


        {
            'name': 'form',
            'fields': {
            'title': 'Contact Us',
            'description': 'Have a question or want to work together? Fill out the form below.'
        }
        },
    ] %}

    {% for block in blocks %}
        {% include 'blocks/main/' ~ block.name ~ '.twig' with
            {
                'block_group': 'main',
                'block_name': block.name,
                'fields': block.fields,
            } %}
    {% endfor %}

{% endblock %}
