<div class="popupWrapper question-popup-wrapper">
    <div class="question-popup">

        <div class="popup-message">
            <p class="popup-message-title">
                Got a question? We'd love to hear from you.
            </p>
        </div>

        <form class="form" novalidate>
            <div class="form-group">
                <label for="question_name">Name</label>
                <input type="text" id="question_name" name="name" placeholder="Your name" required>
            </div>
            <div class="form-group">
                <label for="question_message">Message</label>
                <textarea id="question_message" name="message" placeholder="Your message" required></textarea>
            </div>
            <div class="form-actions">

                {% include "overall/btn.twig" with {
                    class: 'close-question-popup',
                    button: {
                        type: 'button',
                        label: 'cancel question popup',
                        title: 'Cancel',
                    }
                }%}


                {% include "overall/btn.twig" with {
                    class: 'submit-question-popup',
                    button: {
                        type: 'submit',
                        label: 'submit question popup',
                        title: 'Send Question',
                    }
                }%}

            </div>
        </form>
    </div>
</div>
