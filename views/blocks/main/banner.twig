{% extends "overall/block-base.twig" %}

{% block block %}

<div class="banner-section">
    <div class="banner-inner">



        <div class="banner-logo">
            {% include "overall/logo.twig" %}
        </div>

        {% if fields.title is defined and fields.title %}
        <h3 class="banner-title">{{ fields.title }}</h3>
        {% endif %}

        {% if fields.content is defined and fields.content %}
        <div class="typo">
            {{ fields.content|raw }}
        </div>
        {% endif %}
    </div>
</div>

{% endblock %}
