                    </div>
                {% endfor %}
            </div>
            <article class="hero-2-article">
                {% if fields.title is defined and fields.title %}
                    <h1 class="hero-title">{{ fields.title|raw }}</h1>
                {% endif %}

                {% if fields.description is defined and fields.description %}
                    <p class="hero-description typo">{{ fields.description|raw }}</p>
                {% endif %}

                {% if fields.buttons is defined and fields.buttons %}
                    <div class="hero-actions">
                        <span class="thumb"></span>
                        {% for button in fields.buttons %}
                            <button class="hero-btn" data-role="{{ button.role }}" type="button">
                                {{ button.role }}
                            </button>
                        {% endfor %}
                    </div>
                {% endif %}
            </article>
        </div>
    </div>

