{% extends "overall/block-base.twig" %}

{% block block %}

    <div class="hero-2-section">
        <div class="hero-2-inner">
            <div class="hero-2-slider">
                {% for button in fields.buttons %}
                    <div class="hero-slide">
                        <img src="{{ button.img }}" alt="{{ button.role }}">

                        {% if button.decor %}
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1145.1 834.8">
                            <style type="text/css">
                                .hero-2-svg {
                                    fill: none;
                                    stroke: currentColor;
                                    stroke-width: 5;
                                    stroke-linecap: round;
                                    stroke-miterlimit: 10;
                                    stroke-dasharray: 2000;
                                    stroke-dashoffset: -2000;
                                    animation: draw linear forwards;
                                }

                                .p1 { animation-delay: 0.1s; animation-duration: 0.5s; }
                                .p2 { animation-delay: 0.4s; animation-duration: 0.6s; }
                                .p3 { animation-delay: 1.1s; animation-duration: 0.15s; }
                                .p4 { animation-delay: 1.15s; animation-duration: 1s; }
                                .p5 { animation-delay: 2.25s; animation-duration: 0.3s; }

                                @keyframes draw {
                                    to { stroke-dashoffset: 0; }
                                }
                            </style>
                            <path class="p1 hero-2-svg " stroke="red" d="M198.9,234.1c-15-0.5-27.8-2.4-36.9-6.4c-9.7-4.3-15.7-10.1-18.2-17.3c-2.5-7.1-1.5-15.4,2.1-24.2
                                c7.1-17.7,24.8-38.5,47.5-60C238.8,83.1,305,36.5,350.2,6"/>
                            <path class="p2 hero-2-svg " d="M17.9,611.9c-9.7-7.1-11.2-12-14.1-21.8c-4.3-14.5-1.5-31.4,6.6-49.7c16.1-36.6,53.6-79.6,99.8-122.2
                                C203,333,332.1,248.9,400.5,220.5c17.3-7.2,27.9-11.6,32.4-14.6c0.8-0.5,1.7-1,1.4-1.6c-0.2-0.7-1.6-0.7-2.8-0.6
                                c-5.2,0.6-14.5,1.8-27.1,3.9c-9.3,1.5-20.1,3.4-32.1,5.5c-4.3,0.7-8.7,1.5-13.2,2.3c-34.1,5.9-74.7,12.7-111.3,16.2"/>
                            <path class="p3 hero-2-svg " d="M256.3,616.6c-11.5,3.7-14.4,4.5-26.4,7.6"/>
                            <path class="p4 hero-2-svg " d="M619.8,732.3c-197.4,54.1-322.3,81.3-429.8,93.5c-60.4,6.9-105.6,6.6-134-1.6c-14.2-4.1-24.5-10.3-30.2-18.9
                                c-5.8-8.6-6.9-19.2-3.4-31.8c7-25.1,31-52.5,63.6-79.6c21.7-18,47.4-35.9,74.8-53l0.2-0.1l16.5-10l1.4-0.9c8-4.8,16.2-9.5,24.4-14.1
                                c42.9-24,86.9-45.2,124.5-60.9c37.5-15.6,68.6-25.8,85.5-27.6c2.2-0.2,4-0.3,5.6-0.2c1.5,0.1,2.9,0.4,3.9,0.9
                                c1.1,0.5,1.9,1.4,2.2,2.6c0.3,1.1,0,2.3-0.5,3.4c-1,2.1-3.3,4.6-6.4,7.4c-3.1,2.8-7.3,5.9-12.4,9.3c-19.2,12.9-51.5,29.8-90.3,45.3"/>
                            <path class="p5 hero-2-svg " d="M1131.8,544.7c0.4-0.7,1.3-1,2-0.6c1.1,0.5,2,1.4,2.6,2.5s0.6,2.5,0.2,3.8c-0.8,2.6-3.2,5.6-7.4,9
                                c-7.9,6.5-23.1,15.4-48.9,26.9"/>
                        </svg>
                        {% endif %}
                    </div>
                {% endfor %}
            </div>
            <article class="hero-2-article">
                {% if fields.title is defined and fields.title %}
                    <h1 class="hero-title">{{ fields.title|raw }}</h1>
                {% endif %}

                {% if fields.description is defined and fields.description %}
                    <p class="hero-description typo">{{ fields.description|raw }}</p>
                {% endif %}

                {% if fields.buttons is defined and fields.buttons %}
                    <label class="hero-actions">
                        <input type="checkbox">
                        <span class="thumb"></span>
                        {% for button in fields.buttons %}
                            <span class="hero-btn">
                                {{ button.role }}
                            </span>
                        {% endfor %}
                    </label>
                {% endif %}
            </article>
        </div>
    </div>

{% endblock %}