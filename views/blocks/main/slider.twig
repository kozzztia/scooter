{% extends "overall/block-base.twig" %}

{% block block %}

{% if fields is defined and fields %}
<div class="slider-section {% if fields.class %}{{ fields.class }}{% endif %}">
    <div class="slider-inner">
    {% if fields.slides is defined and fields.slides %}
        <div class="swiper slider">
            <div class="swiper-wrapper">
            {% for slide in fields.slides %}
                <div class="swiper-slide slider-slide">
                    {% include 'overall/comment.twig' with slide %}
                </div>
            {% endfor %}
            </div>
        </div>

        <div class="slider-nav">
            {% if  fields.button %}
                {% include 'overall/btn.twig' with { button: fields.button, class: 'review-toggler'}%}
            {% endif %}
            <div class="swiper-pagination bullets"></div>
            <div class="swiper-button-prev prev"></div>
            <div class="swiper-button-next next"></div>
        </div>
    {% endif %}

    {% if fields.decor %}
        <svg class="slider-decor" viewBox="0 0 569.3 430.1" xmlns="http://www.w3.org/2000/svg" fill="none">
            <path class="slider_svg svg" d="M25.8,322.7c-55.8-145.2-4.2-280,77.2-312.4c80.1-31.8,177,40.2,222.8,97.9c80.7,101.8,86.8,265.6,24,307.5
                c-28.8,19.2-73.8,14.1-99-7.5c-40.9-35-29-112.8-1.5-159c41.5-69.6,125.3-79.3,153-82.5c38.5-4.5,86.7-10,111,18
                c29.2,33.6-2.5,85,33,159c7.6,15.8,15.8,27.6,21,34.5"/>
        </svg>
    {% endif %}
    </div>
</div>
{% endif %}

{% endblock %}
