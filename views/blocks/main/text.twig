{% extends "overall/block-base.twig" %}

{% block block %}

{% if fields is defined and fields %}
<div class="text-section {% if fields.class %}{{ fields.class }}{% endif %}">
    <div class="text-inner">
        {% if fields.title is defined and fields.title %}
        <h2 class="text-title">{{ fields.title }}</h2>
        {% endif %}
        {% if fields.content is defined and fields.content %}
        <div class="typo">
            {{ fields.content|raw }}
        </div>
        {% endif %}
    </div>
</div>
{% endif %}

{% endblock %}
